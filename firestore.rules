rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Profiles ---
    match /profiles/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      function isValidNotification(data) {
        return data.userId is string 
          && data.type == "capacity_alert"
          && data.title is string
          && data.message is string
          && data.read == false
          && data.createdAt == request.time;
      }

      allow read, update, delete: if isSignedIn() && isOwner(resource.data.userId);
      // Allow public to create capacity alerts (triggered from RaceEnrollment)
      allow create: if isValidNotification(incoming());
    }

    // --- Races ---
    match /races/{raceId} {
      function isValidRace(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.organizerId is string && data.organizerId.size() > 0
          && data.participationType in ['paid', 'beneficent', 'free']
          && data.type in ['street', 'treadmill', 'online']
          && data.date is string
          && data.time is string
          && data.location is string
          && data.price is number
          && data.capacity is number
          && (data.pixKey == null || data.pixKey is string);
      }

      // Public reads for enrollment pages
      allow read: if true;
      
      // Organizers manage their races
      allow create: if isSignedIn() 
        && isOwner(incoming().organizerId)
        && incoming().createdAt == request.time
        && isValidRace(incoming());
        
      allow update: if isSignedIn()
        && isOwner(existing().organizerId)
        && isOwner(incoming().organizerId)
        && (incoming().createdAt == existing().createdAt)
        && isValidRace(incoming());
        
      allow delete: if isSignedIn()
        && isOwner(existing().organizerId);
    }

    // --- Registrations ---
    match /registrations/{registrationId} {
      function isValidRegistration(data) {
        return isValidId(data.raceId)
          && isValidId(data.organizerId)
          && data.runnerName is string && data.runnerName.size() >= 3 && data.runnerName.size() <= 200
          && data.email is string && data.email.size() > 5 && data.email.size() <= 200
          && data.gender in ['male', 'female']
          && data.jerseySize in ['PP', 'P', 'M', 'G', 'GG', 'EXG', 'EXG2']
          && data.paymentStatus in ['pending', 'confirmed']
          && data.createdAt is string;
      }

      // Organizers can list registrations for their races, runners can list their own by email
      allow list: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid ||
        resource.data.email == request.auth.token.email
      );

      // Public can create a registration
      allow create: if isValidRegistration(incoming()) 
        && exists(/databases/$(database)/documents/races/$(incoming().raceId));

      // Strictly isolate PII: only owner (by email) or organizer can read full details
      allow get: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid ||
        resource.data.email == request.auth.token.email
      );

      // Organizers can update limited fields
      allow update: if isSignedIn() 
        && resource.data.organizerId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['paymentStatus', 'paymentMethod']);
        
      // Organizers can delete registrations for their races
      allow delete: if isSignedIn() && (
        resource.data.organizerId == request.auth.uid || 
        get(/databases/$(database)/documents/races/$(resource.data.raceId)).data.organizerId == request.auth.uid
      );
    }

    // --- Training Plans ---
    match /training_plans/{planId} {
      function isValidPlan(data) {
        return data.userId is string
          && data.title is string
          && data.schedule is list
          && data.tips is list;
      }
      allow read: if true;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidPlan(incoming());
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'lukas.alvesr7@gmail.com';
    }

    // --- Training Subscriptions ---
    match /training_subscriptions/{userId} {
      function isValidSubscription(data) {
        return data.userId == userId
          && data.status in ['active', 'expired', 'awaiting_approval']
          && data.expiresAt is timestamp
          && data.createdAt is timestamp;
      }
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && isValidSubscription(incoming());
      allow update: if isAdmin();
    }

    // --- Trainer Clients ---
    match /trainer_clients/{clientId} {
      function isValidTrainerClient(data) {
        return data.trainerId is string && data.trainerId.size() > 0
          && data.name is string && data.name.size() > 0
          && data.email is string
          && data.status in ['active', 'paused', 'encerrado'];
      }

      allow read: if isSignedIn() && (isOwner(resource.data.trainerId) || resource.data.email == request.auth.token.email);
      allow create: if isSignedIn() && isOwner(incoming().trainerId) && isValidTrainerClient(incoming());
      allow update: if isSignedIn() && isOwner(resource.data.trainerId) && isValidTrainerClient(incoming());
    }

    // --- Workouts ---
    match /workouts/{workoutId} {
      function isValidWorkout(data) {
        return data.trainerId is string
          && data.clientId is string
          && data.status in ['pending', 'in_progress', 'completed', 'em_andamento', 'concluido'];
      }

      allow read: if isSignedIn() && (
        isOwner(resource.data.trainerId) || 
        get(/databases/$(database)/documents/trainer_clients/$(resource.data.clientId)).data.email == request.auth.token.email
      );
      allow create: if isSignedIn() && isOwner(incoming().trainerId) && isValidWorkout(incoming());
      allow update: if isSignedIn() && (
        isOwner(resource.data.trainerId) || 
        get(/databases/$(database)/documents/trainer_clients/$(resource.data.clientId)).data.email == request.auth.token.email
      );
    }

    // --- Training Executions ---
    match /training_executions/{executionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Consultations ---
    match /consultations/{consultationId} {
      function isValidConsultation(data) {
        return data.trainerId is string
          && data.clientId is string
          && data.status in ['scheduled', 'finished', 'canceled'];
      }

      allow read: if isSignedIn() && (
        isOwner(resource.data.trainerId) ||
        get(/databases/$(database)/documents/trainer_clients/$(resource.data.clientId)).data.email == request.auth.token.email
      );
      allow create: if isSignedIn() && isOwner(incoming().trainerId);
      allow update: if isSignedIn() && isOwner(resource.data.trainerId);
    }

    // ─── NEXUS TRAINER AI ───────────────────────────────────────────────

    // Perfil de onboarding do atleta
    match /nexus_profiles/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Plano de treino gerado pela IA
    match /nexus_plans/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Logs de sessões de treino concluídas
    match /nexus_workout_logs/{logId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Medidas corporais
    match /nexus_measurements/{measurementId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Conquistas, XP e sequência
    match /nexus_achievements/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
  }
}
